<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Addplay - <%= song.title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        :root {
            --main-sky-blue: #7cd0ff;
            --light-sky: #e6f7ff;
            --dark-blue: #006699;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --bg-app: #f8fafc;
            --card-bg: #ffffff;
            --border-color: #e2e8f0;
        }
        body { background-color: var(--bg-app); color: var(--text-main); padding: 40px 20px; }
        .container { max-width: 700px; margin: 0 auto; }
        
        .back-btn { display: inline-flex; align-items: center; gap: 8px; color: var(--text-muted); text-decoration: none; font-size: 14px; margin-bottom: 24px; transition: color 0.2s; }
        .back-btn:hover { color: var(--dark-blue); }

        /* --- DETAIL CARD --- */
        .detail-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 42px; box-shadow: 0 4px 6px rgba(0,0,0,0.01); }
        
        .song-header { margin-bottom: 24px; }
        .song-title { font-size: 26px; color: var(--dark-blue); font-weight: 700; margin-bottom: 6px; }
        .song-singer { font-size: 16px; color: var(--text-muted); display: flex; align-items: center; gap: 8px; }

        /* --- VIDEO VIDEO CONTAINER (RESPONSIVE 16:9) --- */
        .video-container { 
            position: relative; 
            width: 100%; 
            aspect-ratio: 16/9; 
            background-color: #000; 
            border-radius: 12px; 
            overflow: hidden; 
            margin-bottom: 24px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        }
        .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }

        /* --- LINKS & FOOTER --- */
        .meta-links { display: flex; flex-direction: column; gap: 12px; padding-top: 16px; border-top: 1px solid var(--border-color); }
        .meta-item { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--text-main); }
        .meta-item a { color: var(--dark-blue); text-decoration: none; word-break: break-all; }
        .meta-item a:hover { text-decoration: underline; }

        .no-video-box { display: flex; flex-direction: column; justify-content: center; align-items: center; height: 100%; color: #94a3b8; text-align: center; padding: 20px; }
    </style>
</head>
<body>
    <!-- <%= JSON.stringify(song) %> -->
    <div class="container">
        <% song.Playlists.forEach(p => { %>
            <a href="/playlist/<%= p.id %>" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back to Track List</a>
        <% }) %>

        <div class="detail-card">
            <header class="song-header">
                <h1 class="song-title"><%= song.title %></h1>
                <div class="song-singer">
                    <i class="fa-solid fa-microphone-lines"></i> <%= song.singer || 'Unknown Artist' %>
                </div>
            </header>

            <div class="video-container">
                <% if (embedYoutubeUrl) { %>
                    <iframe 
                        src="<%= embedYoutubeUrl %>" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                        allowfullscreen>
                    </iframe>
                <% } else { %>
                    <div class="no-video-box">
                        <i class="fa-solid fa-video-slash" style="font-size: 40px; margin-bottom: 12px;"></i>
                        <p style="font-size: 14px;">No playable YouTube link provided for this song.</p>
                    </div>
                <% } %>
            </div>

            <footer class="meta-links">
                <div class="meta-item">
                    <i class="fa-solid fa-link" style="color: var(--main-sky-blue);"></i>
                    <strong>Original URL:</strong>
                    <% if (song.url) { %>
                        <a href="<%= song.url %>" target="_blank"><%= song.url %></a>
                    <% } else { %>
                        <span style="color: var(--text-muted); font-style: italic;">None Provided</span>
                    <% } %>
                </div>
            </footer>
        </div>
    </div>

</body>
</html>