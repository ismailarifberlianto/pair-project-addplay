<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Addplay - Your Playlists</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --main-sky-blue: #7cd0ff;
            --light-sky: #e6f7ff;
            --dark-blue: #006699;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --bg-app: #f8fafc;
            --card-bg: #ffffff;
            --border-color: #e2e8f0;
            --danger-red: #ef4444;
        }

        body {
            background-color: var(--bg-app);
            color: var(--text-main);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        /* --- HEADER SECTION --- */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 24px;
            font-weight: 700;
            color: var(--dark-blue);
        }

        .logo i {
            color: var(--main-sky-blue);
        }

        .nav-item.admin-badge {
            color: var(--dark-blue);
            font-weight: 600;
            background-color: var(--light-sky);
            padding: 6px 14px;
            border-radius: 20px;
            border: 1px solid #7cd0ff;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
        }

        .nav-item.admin-badge:hover {
            background-color: #d0f0ff;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0, 102, 153, 0.1);
        }

        /* --- USER MENU & PROFILE DROPDOWN --- */
        .user-menu-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-profile-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            background: white;
            border: 1px solid var(--border-color);
            padding: 6px 14px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .user-profile-btn:hover {
            border-color: var(--main-sky-blue);
            background-color: var(--light-sky);
        }

        .avatar-circle {
            width: 28px;
            height: 28px;
            background-color: var(--main-sky-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: 600;
            font-size: 12px;
        }

        .username-text {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-main);
        }

        /* Dropdown Menu List */
        .dropdown-menu {
            position: absolute;
            right: 0;
            top: 105%;
            width: 160px;
            background-color: white;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            list-style: none;
            overflow: hidden;
            z-index: 100;
            display: none;
        }

        .profile-dropdown-container {
            position: relative;
            display: inline-block;
        }

        .profile-dropdown-container:hover .dropdown-menu {
            display: block;
        }

        .dropdown-item a,
        .dropdown-item button {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: var(--text-main);
            text-decoration: none;
            font-size: 14px;
            background: none;
            border: none;
            text-align: left;
            cursor: pointer;
            transition: background 0.2s;
        }

        .dropdown-item a:hover,
        .dropdown-item button:hover {
            background-color: var(--light-sky);
            color: var(--dark-blue);
        }

        .dropdown-item.logout-border {
            border-top: 1px solid var(--border-color);
        }

        .dropdown-item.logout-border a,
        .dropdown-item.logout-border button {
            color: var(--danger-red);
        }

        .dropdown-item.logout-border a:hover,
        .dropdown-item.logout-border button:hover {
            background-color: #fef2f2;
            color: var(--danger-red);
        }

        /* --- MAIN HERO / BANNER --- */
        .hero-banner {
            background: linear-gradient(135deg, var(--light-sky) 0%, #b3e5ff 100%);
            padding: 32px;
            border-radius: 16px;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .hero-text h1 {
            font-size: 26px;
            color: var(--dark-blue);
            margin-bottom: 6px;
        }

        .hero-text p {
            font-size: 14px;
            color: #334155;
        }

        /* --- SECTION CONTROLS --- */
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .section-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-main);
        }

        /* Create Playlist Form */
        .add-playlist-form {
            display: flex;
            gap: 10px;
        }

        .input-playlist {
            padding: 10px 16px;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            font-size: 14px;
            width: 240px;
            transition: all 0.3s ease;
        }

        .input-playlist:focus {
            outline: none;
            border-color: var(--main-sky-blue);
            box-shadow: 0 0 0 3px var(--light-sky);
        }

        .btn-add-playlist {
            padding: 10px 20px;
            background-color: var(--main-sky-blue);
            color: white;
            border: none;
            border-radius: 20px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-add-playlist:hover {
            background-color: #5bc0f8;
        }

        .search-section {
            margin-bottom: 24px;
            width: 100%;
        }

        .search-box-wrapper {
            position: relative;
            max-width: 400px;
            /* Limits the search bar width so it looks elegant */
            width: 100%;
        }

        .search-box-wrapper input {
            width: 100%;
            padding: 12px 16px;
            padding-left: 44px;
            /* Leaves space for the magnifying glass icon */
            border: 1px solid var(--border-color);
            border-radius: 24px;
            /* Makes it pill-shaped and modern */
            font-size: 14px;
            color: var(--text-main);
            background-color: #ffffff;
            transition: all 0.3s ease;
        }

        /* Focus glow effect matching your sky-blue theme */
        .search-box-wrapper input:focus {
            outline: none;
            border-color: var(--main-sky-blue);
            box-shadow: 0 0 0 3px var(--light-sky);
        }

        /* Positioning the search icon inside the input box */
        .search-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            pointer-events: none;
            /* Allows user clicks to pass through to the input */
            transition: color 0.3s ease;
        }

        /* Changes icon color when the input box is active */
        .search-box-wrapper:focus-within .search-icon {
            color: var(--dark-blue);
        }

        /* --- PLAYLIST GRID --- */
        .playlist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 24px;
        }

        .playlist-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            color: inherit;
        }

        .playlist-card:hover {
            transform: translateY(-4px);
            border-color: var(--main-sky-blue);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.04);
        }

        .playlist-cover {
            width: 100%;
            aspect-ratio: 1;
            background-color: var(--light-sky);
            border-radius: 10px;
            margin-bottom: 16px;
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--dark-blue);
            font-size: 48px;
        }

        .playlist-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 10px;
        }

        .playlist-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .playlist-count {
            font-size: 13px;
            color: var(--text-muted);
        }

        .success-alert {
            display: flex;
            align-items: center;
            gap: 12px;
            background-color: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 14px 20px;
            border-radius: 12px;
            margin-bottom: 24px;
        }

        .success-icon {
            color: #16a34a;
            font-size: 16px;
        }

        .success-text {
            font-size: 14px;
            color: #16a34a;
            font-weight: 500;
        }

        .error-alert {
            display: flex;
            align-items: center;
            gap: 12px;
            background-color: #fef2f2;
            border: 1px solid #fee2e2;
            border-left: 4px solid #ef4444;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            animation: fadeIn 0.3s ease-in-out;
        }

        .error-icon {
            color: #ef4444;
            font-size: 16px;
            flex-shrink: 0;
        }

        .error-text {
            color: #991b1b;
            font-size: 13px;
            font-weight: 500;
            line-height: 1.4;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-4px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="container">

        <!-- ================= HEADER & PROFILE NAVIGATION ================= -->
        <header class="header">
            <div class="logo">
                <i class="fa-solid fa-cloud-music"></i>
                <span>Addplay</span>
            </div>

            <div class="user-menu-wrapper">
                <% if (findUser) { %>

                    <% if (findUser.role==='admin' ) { %>
                        <a href="/songs" class="nav-item admin-badge" style="text-decoration: none;">
                            <i class="fa-solid fa-music"></i> Manage Songs
                        </a>
                        <% } %>

                            <div class="profile-dropdown-container">
                                <button class="user-profile-btn">
                                    <div class="avatar-circle">
                                        <%= findUser.Profile.username.substring(0,2).toUpperCase() %>
                                    </div>
                                    <span class="username-text">
                                        <%= findUser.Profile.username %>
                                    </span>
                                    <i class="fa-solid fa-chevron-down"
                                        style="font-size: 11px; color: var(--text-muted);"></i>
                                </button>

                                <ul class="dropdown-menu">
                                    <li class="dropdown-item">
                                        <a href="/profile"><i class="fa-solid fa-user"></i> Profile</a>
                                    </li>
                                    <li class="dropdown-item logout-border">
                                        <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                                    </li>
                                </ul>
                            </div>

                            <% } else { %>
                                <a href="/login"><i class="fa-solid fa-right-to-bracket"></i> Login</a>
                                <% } %>
            </div>
        </header>

        <!-- ================= HERO BANNER ================= -->
        <section class="hero-banner">
            <div class="hero-text">
                <h1>Your Personal Music Space</h1>
                <p>Enjoy your favorite music playlists all in one clean place.</p>
            </div>
            <div style="font-size: 40px; color: var(--dark-blue); opacity: 0.6;">
                <i class="fa-solid fa-compact-disc"></i>
            </div>
        </section>


        <!-- ================= CONTROLS & NEW PLAYLIST FORM ================= -->
        <section class="section-header">
            <h2>Playlist Collection</h2>

            <!-- Redirects directly to your dedicated add playlist page -->
            <a href="/playlist/add" class="btn-add-playlist" style="text-decoration: none;">
                <i class="fa-solid fa-plus"></i> Create Playlist
            </a>
        </section>
        <form action="/" method="get">
            <div class="search-box-wrapper">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" name="search" placeholder="Search playlist by name..."
                    value="<%= typeof search !== 'undefined' ? search : '' %>">
                <button type="submit" style="display: none;">Search</button>
            </div>
        </form>
        <br>
        <% if (typeof successMessage !=='undefined' && successMessage) { %>
                <div class="success-alert">
                    <i class="fa-solid fa-circle-check success-icon"></i>
                    <div class="success-text">
                        <%= successMessage %>
                    </div>
                </div>
                <% } %>
                    <% if (typeof errorMessage !=='undefined' && errorMessage) { %>
                        <div class="error-alert">
                            <i class="fa-solid fa-triangle-exclamation error-icon"></i>
                            <div class="error-text">
                                <%= errorMessage %>
                            </div>
                        </div>
                        <% } %>
                        
        <!-- ================= PLAYLIST GRID DISPLAY ================= -->
        <main class="playlist-grid">

            <!-- Backend EJS Controller Loop -->
            <% if (typeof playlists !=='undefined' && playlists.length> 0) { %>
                <% playlists.forEach(p=> { %>
                    <a href="/playlist/<%= p.id %>" class="playlist-card">
                        <div class="playlist-cover">
                            <% if (p.imageUrl && p.imageUrl.trim() !=="" ) { %>
                                <img src="<%= p.imageUrl %>" alt="<%= p.name %> Cover" class="playlist-img">
                                <% } else { %>
                                    <i class="fa-solid fa-music"></i>
                                    <% } %>
                        </div>
                        <div class="playlist-title">
                            <%= p.name %>
                        </div>

                        <div class="playlist-meta-info"
                            style="display: flex; justify-content: space-between; align-items: center; margin-top: 4px;">
                            <div class="playlist-count">
                                <%= p.totalSong %> Songs
                            </div>
                            <div class="playlist-date" style="font-size: 11px; color: var(--text-muted);">
                                <i class="fa-regular fa-calendar" style="margin-right: 4px;"></i>
                                <%= createAt(p.createdAt) %>
                            </div>
                        </div>
                    </a>
                    <% }) %>
                        <% } else { %>
                            <div
                                style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-muted);">
                                <i class="fa-solid fa-folder-open"
                                    style="font-size: 48px; margin-bottom: 12px; color: #cbd5e1;"></i>
                                <p>No playlists found. Create your first playlist above!</p>
                            </div>
                            <% } %>
        </main>
    </div>

</body>

</html>