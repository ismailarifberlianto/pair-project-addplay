<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Addplay - Edit <%= playlistId.name %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* --- RESET & VARIABLES --- */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        }
        
        :root {
            --main-sky-blue: #7cd0ff;
            --light-sky: #e6f7ff;
            --dark-blue: #006699;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --bg-app: #f8fafc;
            --card-bg: #ffffff;
            --border-color: #e2e8f0;
        }

        body {
            background-color: var(--bg-app);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* --- FORM CARD CONTAINER --- */
        .form-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            width: 100%;
            max-width: 500px;
            padding: 32px;
            position: relative;
            box-shadow: 0 10px 25px rgba(0,0,0,0.02);
        }

        /* Fixed floating X Close button */
        .close-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 32px;
            height: 32px;
            background: #fff;
            border: 1px solid var(--border-color);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.2s ease;
        }

        .close-btn:hover {
            color: var(--dark-blue);
            background-color: var(--light-sky);
            border-color: var(--main-sky-blue);
            transform: scale(1.05);
        }

        h2 {
            font-size: 22px;
            color: var(--dark-blue);
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* --- FORM ELEMENTS --- */
        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--text-main);
        }

        input[type="text"], textarea {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 14px;
            color: var(--text-main);
            transition: all 0.3s ease;
        }

        input:focus, textarea:focus {
            outline: none;
            border-color: var(--main-sky-blue);
            box-shadow: 0 0 0 3px var(--light-sky);
        }

        textarea {
            resize: vertical;
            min-height: 100px;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background-color: var(--main-sky-blue);
            color: white;
            border: none;
            border-radius: 25px;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: background 0.2s ease;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background-color: #5bc0f8;
        }
        .error-alert {
            display: flex;
            align-items: center;
            gap: 12px;
            background-color: #fef2f2; 
            border: 1px solid #fee2e2;
            border-left: 4px solid #ef4444; 
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px; 
            animation: fadeIn 0.3s ease-in-out; 
        }

        .error-icon {
            color: #ef4444;
            font-size: 16px;
            flex-shrink: 0;  
        }

        .error-text {
            color: #991b1b;
            font-size: 13px;
            font-weight: 500;
            line-height: 1.4;
        }
        
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-4px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="form-card">
        <a href="/playlist/<%= playlistId.id %>" class="close-btn" title="Cancel and go back">
            <i class="fa-solid fa-xmark"></i>
        </a>
        <h2><i class="fa-solid fa-pen-to-square"></i> Edit Playlist Details</h2>
        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
            <div class="error-alert">
                <i class="fa-solid fa-triangle-exclamation error-icon"></i>
                <div class="error-text"><%= errorMessage %></div>
            </div>
        <% } %>
        
        <form action="/playlist/<%= playlistId.id %>/edit" method="POST">
            
            <div class="form-group">
                <label for="name">Playlist Name</label>
                <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    value="<%= playlistId.name %>" 
                    placeholder="Enter playlist name..." 
                >
            </div>
            
            <div class="form-group">
                <label for="imageUrl">Cover Image URL</label>
                <input 
                    type="text" 
                    id="imageUrl" 
                    name="imageUrl" 
                    value="<%= playlistId.imageUrl || '' %>" 
                    placeholder="https://images.unsplash.com/your-image-url"
                >
            </div>
            
            <div class="form-group">
                <label for="description">Description</label>
                <textarea 
                    id="description" 
                    name="description" 
                    placeholder="Describe your playlist mood or genre..."
                ><%= playlistId.description || '' %></textarea>
            </div>
            
            <button type="submit" class="btn-submit">SaveChanges</button>
        </form>
    </div>

</body>
</html>